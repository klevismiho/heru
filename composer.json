{
  "name": "heru/theme",
  "description": "Heru WordPress theme",
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^1.0",
    "automattic/vipwpcs": "^3.0",
    "brain/monkey": "^2.6"
  },
  "autoload": {
    "psr-4": {
      "Heru\\Theme\\": "inc/",
      "Heru\\Tests\\": "tests/phpunit/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "lint": "vendor/bin/phpcs .",
    "format": "vendor/bin/phpcbf ."
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
