{
  "id": "backstop_default",
  "viewports": [
    {
      "label": "phone",
      "width": 320,
      "height": 480
    },
    {
      "label": "tablet",
      "width": 1024,
      "height": 768
    }
  ],
  "onBeforeScript": "puppet/onBefore.js",
  "onReadyScript": "puppet/onReady.js",
  "scenarios": [
    {
      "label": "Homepage",
      "url": "https://heru.local",
      "selectors": ["document"],
      "delay": 1500,
      "removeSelectors": ["#wpadminbar"]
    }
  ],
  "paths": {
    "bitmaps_reference": "tests/visual/backstop_data/bitmaps_reference",
    "bitmaps_test": "tests/visual/backstop_data/bitmaps_test",
    "engine_scripts": "tests/visual/backstop_data/engine_scripts",
    "html_report": "tests/visual/backstop_data/html_report",
    "ci_report": "tests/visual/backstop_data/ci_report"
  },
  "report": ["browser"],
  "engine": "puppeteer",
  "engineOptions": {
    "args": ["--no-sandbox"]
  },
  "asyncCaptureLimit": 5,
  "asyncCompareLimit": 50,
  "debug": false,
  "debugWindow": false
}
