{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "heru/logo-grid",
	"version": "0.1.0",
	"title": "Logo Grid",
	"category": "heru",
	"icon": "grid-view",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {
		"viewportWidth": 1200
	},
	"supports": {
		"html": false
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Trusted By Industry Experts."
		},
		"buttonText": {
			"type": "string",
			"default": "See the Difference"
		},
		"buttonUrl": {
			"type": "string",
			"default": "#"
		},
		"logos": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object"
			}
		}
	},
	"textdomain": "logo-grid",
	"editorScript": "file:../../assets/build/blocks/logo-grid/index.js",
	"style": "file:../../assets/build/blocks/logo-grid/style-index.css",
	"viewScript": "file:./view.js",
	"render": "file:./render.php"
}