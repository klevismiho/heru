{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "heru/tabs-with-content",
  "version": "0.1.0",
  "title": "Tabs with content",
  "category": "heru",
  "icon": "align-pull-right",
  "description": "Tabs with content",
  "example": {
    "viewportWidth": 1200
  },
  "supports": {
    "html": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "tabs": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "image": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "id": {
                "type": "number"
              },
              "url": {
                "type": "string"
              },
              "alt": {
                "type": "string"
              }
            }
          },
          "itemTitle": {
            "type": "string"
          },
          "itemDescription": {
            "type": "string"
          },
          "listItems": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "buttonText": {
            "type": "string"
          },
          "buttonUrl": {
            "type": "string"
          },
          "showButton": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  },
  "textdomain": "heru",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}