{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "heru/split-with-video",
  "version": "0.1.0",
  "title": "Split Card with Video",
  "category": "heru",
  "icon": "align-pull-right",
  "description": "Split Card with Video",
  "example": {
    "viewportWidth": 1200
  },
  "supports": {
    "html": false
  },
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "FIXATION TARGET"
    },
    "title": {
      "type": "string",
      "default": "Hi! I’m Nora. Sit back, relax, and keep your eyes on me."
    },
    "videoUrl": {
      "type": "string",
      "default": ""
    },
    "videoId": {
      "type": "number",
      "default": 0
    }
  },
  "textdomain": "heru",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}