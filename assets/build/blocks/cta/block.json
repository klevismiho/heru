{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "heru/cta",
  "version": "0.1.0",
  "title": "Call to action",
  "category": "heru",
  "icon": "align-pull-right",
  "description": "Call to action",
  "example": {
    "viewportWidth": 1200
  },
  "supports": {
    "html": false,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "image": {
      "type": "object",
      "default": {}
    },
    "buttons": {
      "type": "array"
    }
  },
  "textdomain": "heru",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}