{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "heru/featured-article",
  "version": "0.1.0",
  "title": "Featured Article",
  "category": "heru",
  "icon": "align-pull-right",
  "description": "Featured Article",
  "example": {
    "viewportWidth": 1200
  },
  "supports": {
    "html": false
  },
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "HERU BLOG"
    },
    "title": {
      "type": "string",
      "default": "What’s New with Heru"
    },
    "newsMode": {
      "type": "string",
      "default": "latest"
    },
    "selectedPostId": {
      "type": "number",
      "default": 0
    }
  },
  "textdomain": "heru",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}